n class=3D"built_in">range</span>(<span class=3D"number">1</span>, <span cl=
ass=3D"number">51</span>):
    s =3D <span class=3D"string">''</span>:
    <span class=3D"keyword">if</span> i % <span class=3D"number">3</span> =
=3D=3D <span class=3D"number">0</span>:
